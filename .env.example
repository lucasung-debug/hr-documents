# ============================================================
# E-Sign Onboarding - Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET=your-256-bit-hex-secret-here

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=hr-esign@your-project.iam.gserviceaccount.com
# Paste the full private key from service account JSON.
# Replace literal newlines with \n in the value.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Sheet tab names (must match exactly)
SHEET_EMPLOYEE_MASTER=EMPLOYEE_MASTER
SHEET_DOCUMENT_STATUS=DOCUMENT_STATUS

# --- Gmail OAuth2 (for Nodemailer) ---
# Create OAuth2 credentials in Google Cloud Console > APIs & Services
GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxx
GMAIL_REFRESH_TOKEN=1//xxxx
GMAIL_SENDER_ADDRESS=hr@yourcompany.com

# HR team recipients — comma-separated
HR_EMAIL_RECIPIENTS=hr@yourcompany.com,manager@yourcompany.com

# --- Application ---
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# --- Puppeteer ---
# Docker deployment: path to system Chromium
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# Vercel deployment: handled automatically via @sparticuz/chromium (no config needed)
