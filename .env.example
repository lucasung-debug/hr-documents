# ============================================================
# E-Sign Onboarding - Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET=your-256-bit-hex-secret-here

# --- Google Sheets (spreadsheet ID & tab names) ---
GOOGLE_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Sheet tab names (must match exactly)
SHEET_EMPLOYEE_MASTER=EMPLOYEE_MASTER
SHEET_DOCUMENT_STATUS=DOCUMENT_STATUS

# --- Gmail OAuth2 (used for BOTH email sending AND Google Sheets access) ---
# Required scopes:
#   https://www.googleapis.com/auth/gmail.send
#   https://www.googleapis.com/auth/spreadsheets
#   https://www.googleapis.com/auth/drive.readonly  (for Sheets → PDF export)
# Create OAuth2 credentials in Google Cloud Console > APIs & Services > OAuth 2.0 Client IDs
# Then re-issue the refresh token after adding the Sheets scope.
GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxx
GMAIL_CLIENT_REFRESH_TOKEN=1//xxxx
GMAIL_SENDER_ADDRESS=hr@yourcompany.com

# HR team recipients — comma-separated
HR_EMAIL_RECIPIENTS=hr@yourcompany.com,manager@yourcompany.com

# --- Application ---
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# --- PDF Generation ---
# 'true': 로컬 pdf-lib 생성 (빠름, Google API 불필요)
# 미설정 또는 'false': Google Sheets 기반 생성 (기존 방식)
USE_LOCAL_PDF=true

# Phase 4 legacy: Sheets 기반 템플릿 (USE_LOCAL_PDF=true 시 무시됨)
USE_SHEETS_TEMPLATES=true

# --- Puppeteer ---
# Docker deployment: path to system Chromium
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# Vercel deployment: handled automatically via @sparticuz/chromium (no config needed)
